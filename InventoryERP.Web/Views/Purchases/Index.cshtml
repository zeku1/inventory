@model IEnumerable<InventoryERP.Data.Models.Purchase>

@{
    ViewData["Title"] = "Purchases";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h1 style="margin: 0;">Purchases</h1>
    <a asp-action="Create" class="btn-primary"><i class="fa-solid fa-plus"></i> Create New Purchase</a>
</div>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ReferenceNumber)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Supplier)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PurchaseDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TotalCost)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ReferenceNumber)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Supplier.Address)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PurchaseDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TotalCost)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                <div class="action-buttons">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-secondary btn-sm"><i class="fa-solid fa-pen-to-square"></i> Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-info btn-sm"><i class="fa-solid fa-circle-info"></i> Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-danger btn-sm"><i class="fa-solid fa-trash"></i> Delete</a>
                </div>
            </td>
        </tr>
}
    </tbody>
</table>
