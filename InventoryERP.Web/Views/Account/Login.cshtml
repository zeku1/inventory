@model InventoryERP.Web.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="full-screen-center">
    <div class="glass-panel" style="width: 400px;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <img src="~/images/logo.png" alt="SmartStock Logo" style="height: 70px; max-width: 100%; object-fit: contain; border-radius: 4px; margin-bottom: 0.5rem;" asp-append-version="true" />
            <h2 style="margin: 0; font-size: 1.75rem; color: var(--text-primary);">SmartStock</h2>
            <p style="margin: 0.25rem 0 0 0; font-size: 0.875rem; color: var(--text-secondary);">Inventory Management System</p>
        </div>
        
        <form asp-controller="Account" asp-action="Login" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
            <div asp-validation-summary="ModelOnly" style="color: var(--danger); margin-bottom: 1rem;"></div>

            <div style="margin-bottom: 1rem;">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="admin@inventory.local" />
                <span asp-validation-for="Email" style="color: var(--danger); font-size: 0.875rem;"></span>
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="Password" style="color: var(--danger); font-size: 0.875rem;"></span>
            </div>

            <div style="margin-bottom: 1.5rem; display: flex; align-items: center;">
                <input asp-for="RememberMe" style="margin-right: 0.5rem;" />
                <label asp-for="RememberMe" style="color: var(--text-secondary);">Remember me</label>
            </div>

            <button type="submit" class="btn-primary" style="width: 100%;">Sign In</button>
        </form>
    </div>
</div>
