@model InventoryERP.Web.Models.UserViewModel

@{
    ViewData["Title"] = "Create User";
}

<div class="glass-panel" style="max-width: 500px; margin: 0 auto;">
    <h2 style="margin-bottom: 1.5rem;">Add New User</h2>
    
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" style="color: var(--danger); margin-bottom: 1rem;"></div>

        <div style="margin-bottom: 1rem;">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" style="color: var(--danger); font-size: 0.875rem;"></span>
        </div>

        <div style="margin-bottom: 1rem;">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control" type="password" />
            <span asp-validation-for="Password" style="color: var(--danger); font-size: 0.875rem;"></span>
        </div>

        <div style="margin-bottom: 1.5rem;">
            <label asp-for="Role" class="form-label"></label>
            <select asp-for="Role" class="form-control">
                <option value="">-- Select Role --</option>
                @foreach(var role in ViewBag.Roles as List<string>)
                {
                    <option value="@role">@role</option>
                }
            </select>
            <span asp-validation-for="Role" style="color: var(--danger); font-size: 0.875rem;"></span>
        </div>

        <div style="display: flex; gap: 1rem;">
            <button type="submit" class="btn-primary" style="flex: 1;">Create</button>
            <a asp-action="Index" class="btn-primary" style="background: transparent; border: 1px solid var(--border); color: var(--text-primary); text-align: center; flex: 1;">Cancel</a>
        </div>
    </form>
</div>
